<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RiverSentry.Mobile.Pages.AboutPage"
             Title="About"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0d1117">

    <Grid RowDefinitions="Auto,*">
        <!-- Back button (hidden when shown as a top-level tab) -->
        <Border x:Name="BackButton"
                Grid.Row="0"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="16,8"
                WidthRequest="36"
                HeightRequest="36"
                StrokeShape="RoundRectangle 18"
                BackgroundColor="#21262d"
                Stroke="#30363d"
                StrokeThickness="1"
                ZIndex="100">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackTapped"/>
            </Border.GestureRecognizers>
            <Label Text="‹"
                   FontSize="22"
                   TextColor="#8b949e"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="-1,-3,0,0"/>
        </Border>

        <!-- Content -->
        <ScrollView Grid.Row="0" Grid.RowSpan="2">
            <VerticalStackLayout Padding="24" Spacing="24" VerticalOptions="Start">

                <!-- Logo -->
                <Image Source="logotransparent.png"
                       HeightRequest="120"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       Margin="0,24,0,0"/>

                <!-- Description -->
                <Label Text="River Sentry is a flood warning system that monitors water levels and provides early alerts to protect lives and property."
                       FontSize="14"
                       TextColor="#8b949e"
                       HorizontalTextAlignment="Center"
                       Margin="16,0"/>

                <!-- Version -->
                <Border BackgroundColor="#161b22"
                        Stroke="#30363d"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Padding="16"
                        HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="Version"
                               TextColor="#8b949e"
                               FontSize="14"/>
                        <Label x:Name="versionLabel"
                               Text="1.0.0"
                               TextColor="#f0f6fc"
                               FontSize="14"
                               FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="#30363d"
                         Margin="32,8"/>

                <!-- Support Section -->
                <Border BackgroundColor="#161b22"
                        Stroke="#30363d"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Support"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#f0f6fc"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
                            <!-- Website -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="🌐"
                                   FontSize="20"
                                   VerticalOptions="Center"/>
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="www.riversentry.com"
                                   FontSize="14"
                                   TextColor="#58a6ff"
                                   TextDecorations="Underline"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnWebsiteTapped"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <!-- Email -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="📧"
                                   FontSize="20"
                                   VerticalOptions="Center"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="sales@riversentry.com"
                                   FontSize="14"
                                   TextColor="#58a6ff"
                                   TextDecorations="Underline"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnEmailTapped"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <!-- Phone -->
                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="📞"
                                   FontSize="20"
                                   VerticalOptions="Center"/>
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="(512) 934-4441"
                                   FontSize="14"
                                   TextColor="#58a6ff"
                                   TextDecorations="Underline"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPhoneTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Warranty Section -->
                <Border BackgroundColor="#161b22"
                        Stroke="#30363d"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Warranty"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#f0f6fc"/>
                        <Label Text="For warranty information and support resources, visit:"
                               FontSize="14"
                               TextColor="#8b949e"/>
                        <Label Text="www.riversentry.com/support"
                               FontSize="14"
                               TextColor="#58a6ff"
                               TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnWarrantyTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </Border>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="#30363d"
                         Margin="32,8"/>

                <!-- Copyright -->
                <Label Text="© 2026 River Sentry"
                       FontSize="13"
                       TextColor="#6e7681"
                       HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RiverSentry.Mobile.Pages.AboutPage"
             Title="About"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0d1117">

    <Grid RowDefinitions="Auto,*">
        <!-- Back button -->
        <Border Grid.Row="0"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="16,8"
                WidthRequest="36"
                HeightRequest="36"
                StrokeShape="RoundRectangle 18"
                BackgroundColor="#21262d"
                Stroke="#30363d"
                StrokeThickness="1"
                ZIndex="100">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackTapped"/>
            </Border.GestureRecognizers>
            <Label Text="‹"
                   FontSize="22"
                   TextColor="#8b949e"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="-1,-3,0,0"/>
        </Border>

        <!-- Content -->
        <ScrollView Grid.Row="0" Grid.RowSpan="2">
            <VerticalStackLayout Padding="24" Spacing="24" VerticalOptions="Start">

                <!-- Logo -->
                <Image Source="logotransparent.png"
                       HeightRequest="120"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       Margin="0,24,0,0"/>

                <!-- App Name -->
                <Label Text="River Sentry"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#f0f6fc"
                       HorizontalOptions="Center"/>

                <!-- Tagline -->
                <Label Text="Flood Warning System"
                       FontSize="16"
                       TextColor="#8b949e"
                       HorizontalOptions="Center"/>

                <!-- Version -->
                <Border BackgroundColor="#161b22"
                        Stroke="#30363d"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Padding="16"
                        HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="Version"
                               TextColor="#8b949e"
                               FontSize="14"/>
                        <Label x:Name="versionLabel"
                               Text="1.0.0"
                               TextColor="#f0f6fc"
                               FontSize="14"
                               FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Description -->
                <Label Text="River Sentry monitors water levels and provides early flood warnings to protect lives and property."
                       FontSize="14"
                       TextColor="#8b949e"
                       HorizontalTextAlignment="Center"
                       Margin="16,0"/>

                <!-- Website Link -->
                <Label Text="www.riversentry.com"
                       FontSize="14"
                       TextColor="#58a6ff"
                       TextDecorations="Underline"
                       HorizontalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnWebsiteTapped"/>
                    </Label.GestureRecognizers>
                </Label>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="#30363d"
                         Margin="32,8"/>

                <!-- Copyright -->
                <Label Text="© 2026 River Sentry"
                       FontSize="13"
                       TextColor="#6e7681"
                       HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>

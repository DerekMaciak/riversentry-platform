<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:RiverSentry.Mobile.Controls"
             x:Class="RiverSentry.Mobile.Pages.DeviceDetailPage"
             Title="Device Details"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0d1117">

    <Grid>
        <!-- WebView fills entire page -->
        <controls:AppWebView x:Name="appWebView"
                             InterceptDeviceDetail="False" />

        <!-- Close button in top-right corner -->
        <Button Text="✕"
                Clicked="OnCloseTapped"
                WidthRequest="36"
                HeightRequest="36"
                CornerRadius="18"
                Padding="0"
                FontSize="16"
                TextColor="#8b949e"
                BackgroundColor="#21262d"
                BorderColor="#30363d"
                BorderWidth="1"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,8,12,0"
                ZIndex="1"
                InputTransparent="False" />
    </Grid>

</ContentPage>

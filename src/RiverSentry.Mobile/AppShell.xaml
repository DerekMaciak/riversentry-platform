<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:RiverSentry.Mobile.Pages"
       xmlns:local="clr-namespace:RiverSentry.Mobile"
       x:Class="RiverSentry.Mobile.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.NavBarIsVisible="False"
       Shell.TabBarBackgroundColor="#0d1117"
       Shell.TabBarForegroundColor="#58a6ff"
       Shell.TabBarUnselectedColor="#8b949e"
       Shell.TabBarTitleColor="#58a6ff"
       BackgroundColor="#0d1117">

    <TabBar>
        <!-- Home Tab - Blazor WebView -->
        <Tab Title="Home" Icon="tab_dashboard.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <!-- Map Tab - Native MAUI Map (singleton to preserve state) -->
        <Tab Title="Map" Icon="tab_map.png">
            <ShellContent x:Name="mapShellContent" />
        </Tab>

        <!-- Devices Tab - Blazor WebView -->
        <Tab Title="Devices" Icon="tab_devices.png">
            <ShellContent ContentTemplate="{DataTemplate local:DevicesPage}" />
        </Tab>

        <!-- Alarms Tab - Blazor WebView -->
        <Tab Title="Alarms" Icon="tab_alerts.png">
            <ShellContent ContentTemplate="{DataTemplate local:AlertsPage}" />
        </Tab>

        <!-- About Tab - shown directly when only one overflow item exists.
             When Locations is re-enabled, swap this back to MorePage:
             <Tab Title="More" Icon="tab_more.png">
                 <ShellContent ContentTemplate="{DataTemplate pages:MorePage}" />
             </Tab> -->
        <Tab Title="About" Icon="tab_about.png">
            <ShellContent ContentTemplate="{DataTemplate pages:AboutPage}" />
        </Tab>
    </TabBar>

</Shell>

<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:RiverSentry.Mobile.Pages"
       xmlns:local="clr-namespace:RiverSentry.Mobile"
       x:Class="RiverSentry.Mobile.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.NavBarIsVisible="False">

    <Shell.Resources>
        <ResourceDictionary>
            <!-- Tab bar colors -->
            <Color x:Key="TabBarBackground">#0d1117</Color>
            <Color x:Key="TabBarSelected">#58a6ff</Color>
            <Color x:Key="TabBarUnselected">#8b949e</Color>
            
            <Style TargetType="TabBar">
                <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource TabBarBackground}"/>
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource TabBarSelected}"/>
                <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TabBarUnselected}"/>
                <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource TabBarSelected}"/>
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <TabBar>
        <!-- Dashboard Tab - Blazor WebView -->
        <Tab Title="Dashboard" Icon="tab_dashboard.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <!-- Map Tab - Native MAUI Map -->
        <Tab Title="Map" Icon="tab_map.png">
            <ShellContent ContentTemplate="{DataTemplate pages:MapPage}" />
        </Tab>

        <!-- Devices Tab - Blazor WebView -->
        <Tab Title="Devices" Icon="tab_devices.png">
            <ShellContent ContentTemplate="{DataTemplate local:DevicesPage}" />
        </Tab>

        <!-- Alarms Tab - Blazor WebView -->
        <Tab Title="Alarms" Icon="tab_alerts.png">
            <ShellContent ContentTemplate="{DataTemplate local:AlertsPage}" />
        </Tab>

        <!-- Locations Tab - Blazor WebView -->
        <Tab Title="Locations" Icon="tab_locations.png">
            <ShellContent ContentTemplate="{DataTemplate local:LocationsPage}" />
        </Tab>
    </TabBar>

</Shell>

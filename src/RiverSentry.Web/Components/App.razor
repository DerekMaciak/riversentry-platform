<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0d1117" />
    <base href="/" />
    <title>River Sentry Platform</title>

    <!-- Open Iconic Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/open-iconic/1.1.1/font/css/open-iconic-bootstrap.min.css" />

    <!-- Leaflet CSS for maps (local) -->
    <link rel="stylesheet" href="lib/leaflet/leaflet.css" />

    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["_content/RiverSentry.UI.Shared/css/riversentry-shared.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["RiverSentry.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="images/shield.png" />
    <HeadOutlet />
    <script>
        // Apply saved theme before page renders to prevent flash
        (function() {
            var theme = localStorage.getItem('rs-theme');
            if (theme === 'light') {
                document.documentElement.style.backgroundColor = '#ffffff';
            } else {
                document.documentElement.style.backgroundColor = '#0d1117';
            }
        })();
    </script>
</head>

<body>
    <!-- Custom Blazor reconnect UI — subtle banner instead of blocking modal -->
    <div id="components-reconnect-modal" class="rs-reconnect-banner">
        <div id="components-reconnect-show" class="rs-reconnect-show">
            <span class="rs-reconnect-spinner"></span> Reconnecting&hellip;
        </div>
        <div id="components-reconnect-failed" class="rs-reconnect-failed">
            Connection lost.
            <button onclick="location.reload()">Reload</button>
        </div>
        <div id="components-reconnect-rejected" class="rs-reconnect-rejected"></div>
    </div>

    <Routes />

    <!-- Leaflet JS for maps (local) -->
    <script src="lib/leaflet/leaflet.js"></script>

    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        // Configure Blazor circuit reconnection for mobile stability
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 30,
                    retryIntervalMilliseconds: function (previousAttempts, maxRetries) {
                        // Exponential backoff: 1s, 2s, 4s, 8s, then cap at 30s
                        var delay = Math.min(1000 * Math.pow(2, previousAttempts), 30000);
                        return delay;
                    }
                }
            }
        });

        // Auto-reload when circuit is rejected (e.g. server restarted/redeployed)
        new MutationObserver(function (mutations) {
            var modal = document.getElementById('components-reconnect-modal');
            if (modal && modal.classList.contains('components-reconnect-rejected')) {
                location.reload();
            }
        }).observe(document.getElementById('components-reconnect-modal'), {
            attributes: true, attributeFilter: ['class']
        });
    </script>

    <!-- Audio playback for alarm sounds -->
    <script>
        window.riverSentryAudio = {
            audio: null,
            play: function(soundFile) {
                this.stop();
                this.audio = new Audio('/_content/RiverSentry.UI.Shared/' + soundFile);
                this.audio.loop = true;
                this.audio.play().catch(err => console.log('Audio play failed:', err));
            },
            stop: function() {
                if (this.audio) {
                    this.audio.pause();
                    this.audio.currentTime = 0;
                    this.audio = null;
                }
            }
        };
    </script>

    <!-- Service Worker Registration -->
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js')
                .catch(err => console.log('Service worker registration failed:', err));
        }

        // Bridge to native app for notifications
        window.sendNativeNotification = function(type, deviceName) {
            // This triggers a navigation that the native WebView intercepts
            window.location.href = 'app://notification/' + type + '?device=' + encodeURIComponent(deviceName);
        };

        // Bridge to native app for tab switching (optional params object)
        window.switchNativeTab = function(tabName, params) {
            var url = 'app://tab/' + tabName;
            if (params) {
                var qs = Object.keys(params).map(function(k) {
                    return encodeURIComponent(k) + '=' + encodeURIComponent(params[k]);
                }).join('&');
                if (qs) url += '?' + qs;
            }
            window.location.href = url;
        };
    </script>
</body>

</html>
